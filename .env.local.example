# OpenAI API Key - Required for AI features
OPENAI_API_KEY=your-openai-api-key-here

# Optional: Set the model to use
OPENAI_MODEL=gpt-4o

# App URL
NEXT_PUBLIC_APP_URL=https://curtisirwin.com

# Resend - Required for contact form
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key-here

# The "from" address (must be from a verified domain in Resend, or use onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=Contact Form <hello@curtisirwin.com>

# Where contact form submissions get delivered
CONTACT_TO_EMAIL=curtisirwin@me.com
